mutate(monthbirth= as.numeric(mobirth),
agew1= (int_year_w6-yrbirth)*12 + as.numeric(int_month_w6)-13-monthbirth, agew1=replace(agew1,agew1<595,-1),
agew2= (int_year_w7-yrbirth)*12 + as.numeric(int_month_w7)-13-monthbirth, agew2=replace(agew2,agew2<595,-1),
monthdeath= as.numeric(deceased_month)-4,
monthdeath=replace(monthdeath,0,1), monthdeath=replace(monthdeath,-1,6),
agedeath= (deceased_year-yrbirth)*12 + monthdeath-monthbirth,
agedeath=replace(agedeath,NA,-99),
agedeath=replace(agedeath,agedeath< -99,-99)) %>%
filter(agedeath>600|agedeath<0, agew1>599) %>%
droplevels() %>%
mutate(int_year_w6=replace(int_year_w6,(agew1>=agedeath & agedeath>0),-91),
int_year_w7=replace(int_year_w7,(agew2>=agedeath & agedeath>0),-91),
weight6=replace(weight6,agew1==-91,NA),
agew1=replace(agew1,is.na(weight6),-1),
cname=substr(mergeid,1,2),
cname=recode(cname,"Eg"="ES","F1"="FR","Cf"="CH","Cg"="CH","Ci"="CH","Bf"="BE","Bn"="BE")) %>%
filter(country!=25, cname!="PT") %>% #remove portugal very small sample
mutate(deceased_year=ifelse((deceased_year>2017),-1,deceased_year),
sex=ifelse(sex==1,"M","F"),
int_year_w1=int_year_w6,
int_year_w2=int_year_w7,
int_month_w1=int_month_w6,
int_month_w2=int_month_w7) %>%
filter(!is.na(weight6)) %>%
select(-c(int_year_w6,int_year_w7,int_month_w6,int_month_w7)) %>%
filter(agew1<=1080)   #select only those aged 90 in wave 6
########sum of weights by country and sex in each dataset
