startf2 <- "ftol=1.e-18 stepm=3 ncovcol=0 nqv=0 ntv=0 nqtv=0 nlstate=2 ndeath=1 maxwav=2 mle=1 weight=1"
startf3 <- "model=1+age+."
endf <- readLines("C://Users/mmusz//Dropbox//collaborations//with_Agnieszka//IMACH//IMACHgenericall.txt")
writeLines(c(startf1,startf2,startf3,param1,endf), paste("C://Users/mmusz//Dropbox//collaborations//with_Agnieszka//IMACH//",ourcountry,oursex, "frail4.txt",sep=""))
