registerDoParallel(num_cores_available)
sexall <- c("M","F")
for (i in 1:length(country)){
ourcountry <- country[i]
for (j in 1:length(sexall)) {
oursex <- sexall[j]
html <- readLines(paste("C://Users/mmusz//Dropbox//collaborations//with_Agnieszka//IMACH//", ourcountry,oursex,"frail3.htm", sep=""),warn=FALSE)[50:53]
param1 <- as.matrix(str_replace_all(html,"[<tr>d/]",""))
