######################################################sqared age cases
# Function to calculate the probability
calculate_probability2 <- function(a, b1,b2, age) {
exp_term <- -(as.numeric(a) + as.numeric(b1) * age  + as.numeric(b2)*age*age)
probability <- 1 / (1 + exp(exp_term))
return(probability)
}
###gali
