health <- unique(sapply(alldirs, function(x) substr(x, 4, nchar(x))))
#############################################################################################
##### monthly probabilities
extract_data <- function(row) {
# Remove HTML tags
row <- gsub("<.*?>", "", row)
# Split the row into individual elements
data <- unlist(strsplit(row, "\\s+"))
# Remove empty elements
data <- data[data != ""]
# Return the cleaned data
return(data)
}
age <- seq(from=50, to=120, by=1/12)
###gali
k=3
myhealth <- health[k]
myhealth
for (j in 1:length(sex)){
for (i in 1:length(countries)){
mycountry <- countries[i]
mysex <- sex[j]
#step 1: remove the old probability
mprobs <- read.table(file="mprobs.txt",sep=",", header=TRUE) %>%
filter(country!=mycountry|sex!=mysex|health!=myhealth)
write.table(mprobs, file="mprobs.txt",sep=",", row.names=FALSE)
allhtml <- matrix(readLines(paste("C://Users//mmusz//Dropbox//gender_paradox//data//IMACHnew//",countries[i],sex[j],health[k],".htm", sep=""))[50:54])
cleaned_data <- lapply(allhtml, extract_data)
df <- do.call(rbind, cleaned_data)
df <- as.data.frame(df, stringsAsFactors = FALSE)
df <- cbind(df,countries[i],sex[j],health[k])
colnames(df) <- c("pij","a","b1","b2", "Country","Sex","Health")
write.table(df, file="transitions.txt",sep=",", row.names=FALSE)
# Apply the function to each row to calculate the probabilities for each age
probabilities <- apply(df, 1, function(row) {
calculate_probability2(row["a"], row["b1"], row["b2"], age)
})
newprob <- cbind(probabilities, age*12, countries[i],sex[j],health[k])
colnames(newprob) <- c(df$pij, "age","country","sex","health")
write.table(newprob, file="mprobs.txt",sep=",", row.names=FALSE, col.names = FALSE, append=TRUE)
}
}
