Hprobm <- probs%>%
mutate(to1=X11,to2=X12,to3=X13) %>%
select(age,to1,to2,to3,country,sex) %>%
mutate(start="H") %>%
add_row(probs%>%
mutate(to1=X21,to2=X22,to3=X23) %>%
select(age,to1,to2,to3,country,sex) %>%
mutate(start="U"))%>%
arrange(sex,start,country,age) %>%
select(to1,to2,to3)
