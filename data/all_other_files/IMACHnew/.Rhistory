library(tidyr)
library(dplyr)
library(purrr)
library(nnet)
library(stringr)
library(doParallel)
country <- c("AT","BE","CZ","DE","DK","EE","ES","FR","GR","HR","IT","PL","PT","SE")
num_cores_available <- detectCores()
registerDoParallel(num_cores_available)
sexall <- c("M","F")
for (i in c(1:12,length(country))){
ourcountry <- country[i]
for (j in 1:length(sexall)) {
oursex <- sexall[j]
html <- readLines(paste("C://Users/mmusz//Dropbox//gender_paradox//data//IMACHnew//", ourcountry,oursex,"gali.htm", sep=""),warn=FALSE)[50:53]
param1 <- as.matrix(str_replace_all(html,"[<tr>d/]",""))
startf1 <- paste("title=gali datafile=data", ourcountry, oursex, "gali.txt lastobs=5000 firstpass=1 lastpass=2", sep="")
startf2 <- "ftol=1.e-40 stepm=6  ncovcol=0 nqv=0 ntv=0 nqtv=0 nlstate=2 ndeath=1 maxwav=2 mle=1 weight=1"
startf3 <- "model=1+age+age*age."
endf <- readLines("C://Users/mmusz//Dropbox//gender_paradox//data//IMACHnew//IMACHgenericall2.txt")
writeLines(c(startf1,startf2,startf3,param1,endf), paste("C://Users/mmusz//Dropbox//gender_paradox//data//IMACHnew//",ourcountry,oursex,"gali.txt",sep=""))
system2("C:\\Program Files\\IMaCh-0.99r45\\bin\\IMaCh.exe", paste("C:\\Users\\mmusz\\Dropbox\\gender_paradox\\data\\IMACHnew\\",ourcountry,oursex,"gali.txt",sep=""),wait=FALSE)
}
}
